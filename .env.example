# Copy to .env and fill in real values. Never commit .env to git.

# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# Database connection (override the default in configs/orbflow.yaml)
# DATABASE_URL=postgres://orbflow:CHANGE_ME@localhost:5432/orbflow?sslmode=require

# Postgres password for docker-compose
# POSTGRES_PASSWORD=CHANGE_ME
